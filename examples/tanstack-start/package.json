{
  "name": "tanstack-start",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "dev:cf": "USE_CF=1 vite dev --port 3000",
    "build:cf": "USE_CF=1 vite build",
    "preview:cf": "USE_CF=1 vite preview",
